#%RAML 1.0
title: Object Store 2.0 Learning API
version: v1
baseUri: /api/v1
mediaType: application/json
protocols: [ HTTP, HTTPS ]

types:
  CacheEntry:
    type: object
    additionalProperties: false
    properties:
      key:
        type: string
        minLength: 1
      value: any
    example:
      value:
        key: greeting
        value:
          message: Hello from Object Store 2.0
  CacheKeyResult:
    type: object
    additionalProperties: false
    properties:
      key: string
      exists: boolean
  ErrorResponse:
    type: object
    additionalProperties: false
    properties:
      error: string
      message: string

/cache-value:
  post:
    description: Store a JSON value under a key using os:store.
    body:
      application/json:
        type: CacheEntry
    responses:
      201:
        body:
          application/json:
            example:
              key: greeting
              cached: true

/list-cache-keys:
  get:
    description: List every key in the object store using os:retrieve-all-keys.
    responses:
      200:
        body:
          application/json:
            type: string[]
            example: [ greeting ]

/check-cache-key/{key}:
  uriParameters:
    key:
      type: string
      minLength: 1
  get:
    description: Check whether a key exists using os:contains.
    responses:
      200:
        body:
          application/json:
            type: CacheKeyResult
            example:
              key: greeting
              exists: true

/get-value/{key}:
  uriParameters:
    key:
      type: string
      minLength: 1
  get:
    description: Retrieve a cached value using os:retrieve. A missing key returns 404.
    responses:
      200:
        body:
          application/json:
            type: any
      404:
        body:
          application/json:
            type: ErrorResponse

/get-value-default/{key}:
  uriParameters:
    key:
      type: string
      minLength: 1
  get:
    description: Retrieve a value using os:retrieve and its os:default-value fallback.
    queryParameters:
      defaultValue:
        type: string
        required: false
        default: Cache miss
        description: Value returned when the key is not present.
    responses:
      200:
        body:
          application/json:
            type: any

/delete-value/{key}:
  uriParameters:
    key:
      type: string
      minLength: 1
  delete:
    description: Remove and return a cached value using os:remove. A missing key returns 404.
    responses:
      200:
        body:
          application/json:
            type: any
      404:
        body:
          application/json:
            type: ErrorResponse
