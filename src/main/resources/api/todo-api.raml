#%RAML 1.0
title: BadSSL TLS API
version: v1
baseUri: /api/v1
mediaType: application/json
protocols: [ HTTP, HTTPS ]

types:
  BadSslResponse:
    type: object
    additionalProperties: false
    properties:
      target: string
      status: integer
      reasonPhrase?: string
      body: string
  ErrorResponse:
    type: object
    additionalProperties: false
    properties:
      error: string
      message: string

traits:
  hasCorrelationId:
    headers:
      x-correlation-id?:
        type: string
        description: Optional caller supplied correlation id.

/mtls:
  /client-badssl:
    is: [hasCorrelationId]
    get:
      description: Calls https://client.badssl.com/ with the BadSSL client certificate configured for mutual TLS.
      responses:
        200:
          body:
            application/json:
              type: BadSslResponse
              example:
                target: https://client.badssl.com/
                status: 200
                reasonPhrase: OK
                body: "client.badssl.com"
        502:
          body:
            application/json:
              type: ErrorResponse
/tls:
  /self-signed-badssl:
    is: [hasCorrelationId]
    get:
      description: Calls https://self-signed.badssl.com/ using the configured truststore for that self-signed certificate.
      responses:
        200:
          body:
            application/json:
              type: BadSslResponse
        502:
          body:
            application/json:
              type: ErrorResponse
